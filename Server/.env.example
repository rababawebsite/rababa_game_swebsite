PORT=5000
MONGODB_URI=mongodb://localhost:27017/rababa-games
JWT_SECRET=change_this_to_a_long_random_secret
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5173
NODE_ENV=development

# Super admin seed values
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=SuperAdmin

# Use one of these:
# 1) Plain password (server will hash it on first seed)
ADMIN_PASSWORD=ChangeMe@123
# 2) Pre-hashed password (preferred in production)
# ADMIN_PASSWORD_HASH=$2a$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ImageKit Cloud Storage
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Contact form email delivery (optional but recommended)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your_smtp_password
CONTACT_FROM_EMAIL=no-reply@yourdomain.com
CONTACT_TO_EMAIL=support@yourdomain.com
